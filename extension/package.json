{
  "name": "drift-analyzer",
  "displayName": "Drift Analyzer",
  "description": "Detect and classify CloudFormation drift inside VS Code.",
  "version": "0.0.1",
  "publisher": "capstone-project",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:driftAnalyzer",
    "onView:chatbotView",
    "onCommand:driftAnalyzer.runDriftCheck"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "driftAnalyzer",
          "title": "Drift Analyzer",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "driftAnalyzer": [
        {
          "id": "driftAnalyzer",
          "name": "Stacks"
        },
        {
          "id": "chatbotView",
          "type": "webview",
          "name": "AI Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "driftAnalyzer.runDriftCheck",
        "title": "Drift Analyzer: Run Drift Check"
      },
      {
        "command": "driftAnalyzer.refreshStack",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "driftAnalyzer.newChatSession",
        "title": "New Chat Session",
        "icon": "$(add)"
      },
      {
        "command": "driftAnalyzer.chatHistory",
        "title": "Chat History",
        "icon": "$(history)"
      },
      {
        "command": "driftAnalyzer.clearChat",
        "title": "Clear Chat",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "driftAnalyzer.refreshStack",
          "when": "view == driftAnalyzer",
          "group": "navigation"
        },
        {
          "command": "driftAnalyzer.newChatSession",
          "when": "view == chatbotView",
          "group": "navigation"
        },
        {
          "command": "driftAnalyzer.chatHistory",
          "when": "view == chatbotView",
          "group": "navigation"
        },
        {
          "command": "driftAnalyzer.clearChat",
          "when": "view == chatbotView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "driftAnalyzer.runDriftCheck",
          "when": "view == driftAnalyzer && viewItem == stackItem",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "My Extension",
      "properties": {
        "myExtension.awsRegion": {
          "type": "string",
          "default": "us-east-1",
          "enum": [
            "us-east-1",
            "us-west-2",
            "eu-central-1",
            "ap-southeast-1"
          ],
          "description": "AWS region to use for CloudFormation"
        },
        "myExtension.statusFilter": {
          "type": "array",
          "default": [
            "CREATE_COMPLETE",
            "UPDATE_COMPLETE"
          ],
          "items": {
            "type": "string",
            "enum": [
              "CREATE_COMPLETE",
              "CREATE_FAILED",
              "CREATE_IN_PROGRESS",
              "DELETE_COMPLETE",
              "DELETE_FAILED",
              "DELETE_IN_PROGRESS",
              "IMPORT_COMPLETE",
              "IMPORT_IN_PROGRESS",
              "IMPORT_ROLLBACK_COMPLETE",
              "IMPORT_ROLLBACK_FAILED",
              "IMPORT_ROLLBACK_IN_PROGRESS",
              "REVIEW_IN_PROGRESS",
              "ROLLBACK_COMPLETE",
              "ROLLBACK_FAILED",
              "ROLLBACK_IN_PROGRESS",
              "UPDATE_COMPLETE",
              "UPDATE_COMPLETE_CLEANUP_IN_PROGRESS",
              "UPDATE_FAILED",
              "UPDATE_IN_PROGRESS",
              "UPDATE_ROLLBACK_COMPLETE",
              "UPDATE_ROLLBACK_COMPLETE_CLEANUP_IN_PROGRESS",
              "UPDATE_ROLLBACK_FAILED",
              "UPDATE_ROLLBACK_IN_PROGRESS"
            ]
          },
          "description": "Choose one or more stack statuses to display."
        }
      }
    }
  },
  "workspaces": [
    "webview"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && npm run build:webview",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "build:webview": "npm --prefix webview run build:treeView && npm --prefix webview run build:editorView",
    "watch:ts": "tsc -w -p ./"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.9.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/vscode": "^1.85.0",
    "tslint": "^6.1.3",
    "vite-plugin-svgr": "^4.5.0"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agentcore": "^3.956.0",
    "@aws-sdk/client-cloudformation": "^3.902.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.1"
  }
}